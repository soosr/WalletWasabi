<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="using:WalletWasabi.Gui.Converters"
             xmlns:vm="using:WalletWasabi.Gui.ViewModels"
             xmlns:behaviors="clr-namespace:WalletWasabi.Fluent.Behaviors"
             xmlns:c="clr-namespace:WalletWasabi.Fluent.Controls"
             mc:Ignorable="d" d:DesignWidth="671" d:DesignHeight="32"
             x:DataType="vm:StatusBarViewModel"
             x:CompileBindings="True"
             x:Class="WalletWasabi.Fluent.Views.StatusBar.StatusBar">
  <Panel Background="{DynamicResource RegionColor}">
    <PathIcon Data="{StaticResource checkmark_circle_filled}"
              Foreground="{StaticResource SystemAccentColor}"
              VerticalAlignment="Center" HorizontalAlignment="Right"
              Height="20"
              Margin="10 0"
              Name="AttachedFlyoutPanel">
      <Interaction.Behaviors>
        <behaviors:ShowFlyoutOnPointerOverBehavior />
      </Interaction.Behaviors>
      <FlyoutBase.AttachedFlyout>
        <Flyout Placement="Top" ShowMode="TransientWithDismissOnPointerMoveAway">
          <Panel TextBlock.Foreground="{DynamicResource TextControlForeground}"
                 TextBlock.FontSize="14">
            <Border CornerRadius="4">
              <StackPanel Spacing="16">
                <c:StatusItem Icon="{StaticResource checkmark_filled}"
                              Title="Tor"
                              StatusText="is running"/>
                <c:StatusItem Icon="{StaticResource connector_regular}"
                              Title="Backend"
                              StatusText="is running" />
                <c:StatusItem Icon="{StaticResource entities_regular}"
                              Title="Peers"
                              StatusText="3 connected" />
              </StackPanel>
            </Border>
          </Panel>
        </Flyout>
      </FlyoutBase.AttachedFlyout>
    </PathIcon>
  </Panel>

  <!-- <Panel Background="{DynamicResource StatusBarControlBackground}" Cursor="{Binding UpdateAvailable, Converter={StaticResource ShowCursorConverter}}"> -->
